\@writefile{toc}{\contentsline {paragraph}{Cloud-native end-to-end workflow}{21}{section*.12}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Cloud-native usage scenario: from a STAC catalogue query to a derived spectral index in three command-line invocations. The first \texttt  {stac composite} call performs HTTP range reads against the source COG assets, applies the catalogue's cloud-mask convention (SCL for Sentinel-2 L2A or QA\_PIXEL for Landsat), and reduces the temporal stack to a per-band median composite. The second \texttt  {imagery ndvi} call combines the red and NIR composite bands. End-to-end runtime is approximately 65\,s on a 5$\times $5\,km bounding box over a residential connection, with no intermediate Python glue or shell pipelines.}}{22}{figure.2}\protected@file@percent }
\newlabel{fig:workflow}{{2}{22}{Cloud-native usage scenario: from a STAC catalogue query to a derived spectral index in three command-line invocations. The first \texttt {stac composite} call performs HTTP range reads against the source COG assets, applies the catalogue's cloud-mask convention (SCL for Sentinel-2 L2A or QA\_PIXEL for Landsat), and reduces the temporal stack to a per-band median composite. The second \texttt {imagery ndvi} call combines the red and NIR composite bands. End-to-end runtime is approximately 65\,s on a 5$\times $5\,km bounding box over a residential connection, with no intermediate Python glue or shell pipelines}{figure.2}{}}
\citation{amatulli2018}
